rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // ヘルパー関数
    // ============================================

    // 認証済みユーザーかチェック
    function isAuthenticated() {
      return request.auth != null;
    }

    // 自分自身かチェック
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 会話の参加者かチェック
    function isParticipant(conversationData) {
      return isAuthenticated() && request.auth.uid in conversationData.participantIds;
    }

    // 友達関係の当事者かチェック
    function isFriendshipMember(friendshipData) {
      return isAuthenticated() &&
        (request.auth.uid == friendshipData.requesterId ||
         request.auth.uid == friendshipData.receiverId);
    }

    // ============================================
    // users コレクション
    // ============================================
    match /users/{userId} {
      // 読み取り: 認証済みユーザーのみ（友達検索用にvisibleUserIdでの検索を許可）
      allow read: if isAuthenticated();

      // 作成: Cloud Functions経由のみ（認証トリガーで作成）
      allow create: if false;

      // 更新: 自分自身のみ、かつ変更可能フィールドのみ
      allow update: if isOwner(userId) &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['nickname', 'profileImageUrl', 'fcmToken', 'updatedAt', 'lastLoginAt']);

      // 削除: Cloud Functions経由のみ
      allow delete: if false;
    }

    // ============================================
    // conversations コレクション
    // ============================================
    match /conversations/{conversationId} {
      // 読み取り: 参加者のみ
      allow read: if isParticipant(resource.data);

      // 作成: 認証済みユーザーで、自分が参加者に含まれている
      allow create: if isAuthenticated() &&
        request.auth.uid in request.resource.data.participantIds &&
        request.resource.data.participantIds.size() == 2;

      // 更新: 参加者のみ（lastMessage, unreadCount, updatedAtの更新）
      allow update: if isParticipant(resource.data) &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['lastMessage', 'unreadCount', 'updatedAt']);

      // 削除: 不可（パニック削除はCloud Functions経由）
      allow delete: if false;

      // ----------------------------------------
      // messages サブコレクション
      // ----------------------------------------
      match /messages/{messageId} {
        // 読み取り: 会話の参加者のみ
        allow read: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;

        // 作成: 会話の参加者で、送信者が自分自身
        allow create: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds &&
          request.resource.data.senderId == request.auth.uid;

        // 更新: 送信者のみ（削除フラグの更新）または受信者（既読フラグの更新）
        allow update: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds &&
          (
            // 送信者: 削除フラグの更新
            (resource.data.senderId == request.auth.uid &&
             request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isDeleted', 'deletedAt']))
            ||
            // 受信者: 既読フラグの更新
            (resource.data.senderId != request.auth.uid &&
             request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead', 'readAt']))
          );

        // 削除: 不可（論理削除のみ）
        allow delete: if false;
      }
    }

    // ============================================
    // friendships コレクション
    // ============================================
    match /friendships/{friendshipId} {
      // 読み取り: 当事者のみ
      allow read: if isFriendshipMember(resource.data);

      // 作成: 認証済みで、自分がrequesterである
      allow create: if isAuthenticated() &&
        request.resource.data.requesterId == request.auth.uid &&
        request.resource.data.status == 'pending';

      // 更新: 当事者のみ
      allow update: if isFriendshipMember(resource.data) &&
        (
          // 受信者: ステータスをpendingからacceptedに変更
          (resource.data.receiverId == request.auth.uid &&
           resource.data.status == 'pending' &&
           request.resource.data.status == 'accepted')
          ||
          // 当事者: ブロック操作
          (request.resource.data.status == 'blocked' &&
           request.resource.data.blockedBy == request.auth.uid)
          ||
          // ブロック解除（ブロックした人のみ）
          (resource.data.status == 'blocked' &&
           resource.data.blockedBy == request.auth.uid &&
           request.resource.data.status == 'accepted' &&
           request.resource.data.blockedBy == null)
        );

      // 削除: 当事者のみ（友達解除・申請拒否）
      allow delete: if isFriendshipMember(resource.data);
    }

    // ============================================
    // subscriptions コレクション
    // ============================================
    match /subscriptions/{userId} {
      // 読み取り: 自分のみ
      allow read: if isOwner(userId);

      // 作成・更新・削除: Cloud Functions経由のみ
      allow create, update, delete: if false;
    }
  }
}
