{
  "compilerOptions": {
    "module": "commonjs",
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "outDir": "lib",
    "sourceMap": true,
    "strict": true,
    "target": "es2018",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@auth/*": ["src/auth/*"],
      "@messaging/*": ["src/messaging/*"],
      "@friends/*": ["src/friends/*"],
      "@subscription/*": ["src/subscription/*"],
      "@scheduled/*": ["src/scheduled/*"],
      "@panic/*": ["src/panic/*"],
      "@utils/*": ["src/utils/*"]
    },
    "types": ["node"]
  },
  "compileOnSave": true,
  "include": ["src/**/*"],
  "exclude": ["src/**/__tests__/**", "src/**/*.test.ts", "src/**/*.spec.ts"]
}
